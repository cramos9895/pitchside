# ==============================================================================
# PITCHSIDE - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env.local`
# 2. Fill in the values for your specific environment (Dev/Test)
# 3. NEVER commit `.env.local` or `.env.production` to version control.
#
# ==============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Configuration
RESEND_API_KEY=
ENABLE_EMAILS=

# Other Configurations
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_TELEMETRY_DISABLED=
